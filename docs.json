{
  "$schema": "https://mintlify.com/docs.json",
  "name": "WPM Typing Tutor",
  "theme": "aspen",
  "colors": {
    "primary": "#39d353",
    "light": "#56d4dd",
    "dark": "#e3c16f"
  },
  "favicon": "/favicon.ico",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/MarkillerLT/wpmtype"
    }
  },
  "footer": {
